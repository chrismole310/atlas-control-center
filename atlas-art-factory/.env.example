# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=atlas_art_factory
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI APIs
OPENAI_API_KEY=           # platform.openai.com — DALL-E 3 + SEO descriptions
ANTHROPIC_API_KEY=        # console.anthropic.com — Claude Haiku for SEO titles/tags
REPLICATE_API_TOKEN=      # replicate.com — FLUX.1 schnell/dev + CLIP quality scoring
CLOUDFLARE_AI_TOKEN=      # dash.cloudflare.com/profile/api-tokens — Workers AI (free 10k/day)
CLOUDFLARE_ACCOUNT_ID=    # 32-char hex, right sidebar on dash.cloudflare.com
HUGGINGFACE_API_TOKEN=    # huggingface.co/settings/tokens — Inference API
IDEOGRAM_API_KEY=         # ideogram.ai — typography-in-art generation
GOAPI_KEY=                # goapi.ai — Midjourney via 3rd party (optional)

# Etsy — developers.etsy.com/documentation
ETSY_API_KEY=             # OAuth2 app key (keystring)
ETSY_API_SECRET=          # OAuth2 app secret
ETSY_ACCESS_TOKEN=        # OAuth2 access token (after user auth flow)
ETSY_SHOP_ID=             # your numeric shop ID

# Gumroad — app.gumroad.com/settings/advanced
GUMROAD_ACCESS_TOKEN=     # API access token

# Pinterest — developers.pinterest.com
PINTEREST_ACCESS_TOKEN=   # OAuth2 access token
PINTEREST_BOARD_ID=       # target board ID for art pins

# Redbubble — Playwright automation (your account credentials)
REDBUBBLE_EMAIL=
REDBUBBLE_PASSWORD=

# Society6 — Playwright automation (your account credentials)
SOCIETY6_EMAIL=
SOCIETY6_PASSWORD=

# App
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
